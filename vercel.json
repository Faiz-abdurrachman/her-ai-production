{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/__gas",
      "destination": "/api/gas"
    },
    {
      "source": "/__settings",
      "destination": "/api/settings"
    },
    {
      "source": "/((?!api|css|js|assets|components|gas|materi|pages|scripts).*)$",
      "destination": "/index.html"
    }
  ]
}
